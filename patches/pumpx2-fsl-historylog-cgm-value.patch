+    /**
+     * Big-endian signed int16 (network order), e.g. Tandem web / tconnectsync CGM fields.
+     * Differs from {@link #readShort} which is little-endian (low byte first).
+     */
+    public static int readSignedShortBigEndian(byte[] raw, int i) {
+        Validate.isTrue(i >= 0 && i + 1 < raw.length);
+        int unsigned = ((andWithMaxValue(raw[i]) & 255) << 8) | (andWithMaxValue(raw[i + 1]) & 255);
+        if (unsigned >= 0x8000) {
+            return unsigned - 65536;
+        }
+        return unsigned;
+    }
+
     public static float readFloat(byte[] raw, int i) {
         Validate.isTrue(i >= 0 && i + 3 < raw.length);
         return ByteBuffer.wrap(Arrays.copyOfRange(raw, i, i+4)).order(ByteOrder.LITTLE_ENDIAN).getFloat();
